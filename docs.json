  "api": {
    "openapi": "openapi/sec-api.v1.json",
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "url": "full",
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript"
      ],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    }
